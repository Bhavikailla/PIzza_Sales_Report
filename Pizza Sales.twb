        <zone forceUpdate='true' h='29000' id='22' type-v2='text' w='16500' x='1938' y='33778'>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#9c3d3e' fontname='Times New Roman' fontsize='12' underline='true'>HOURS</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>Peak orders are </run>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Times New Roman' fontsize='12'>between 12:00PM and 1:00PM</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='12'> , and in evening,</run>
            <run bold='true' fontalignment='1' fontcolor='#d3b348' fontname='Times New Roman' fontsize='12'>Æ </run>
            <run bold='true' fontalignment='1' fontcolor='#9e049e' fontname='Times New Roman' fontsize='12'>from 4:00PM to 7:00PM</run>
            <run fontalignment='1'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#cb4400' fontname='Times New Roman' fontsize='12' underline='true'>WEEKS</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run bold='true' fontalignment='1' fontcolor='#150588' fontname='Times New Roman' fontsize='12'>Significant variations in weekly orders</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='12'>, with highest peak during the </run>
            <run bold='true' fontalignment='1' fontcolor='#8f0000' fontname='Times New Roman' fontsize='12'>48th week</run>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='12'> from the </run>
            <run bold='true' fontalignment='1' fontcolor='#7100aa' fontname='Times New Roman' fontsize='12'>month of December.</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='background-color' value='#b8ae1be7' />
          </zone-style>
        </zone>
